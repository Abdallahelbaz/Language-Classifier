    "for cls, group in data.groupby('label'):\n",
    "    text = ' '.join(group['clean'])\n",
    "    count[cls]=Counter(text.split())\n",
    "\n",
    "for class_name, counts in count.items():\n",
    "    print(f\"\\nClass {class_name}:\")\n",
    "    print(counts)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cd9e01fb",
   "metadata": {},
   "source": [
    "# **Phase 3 : Convert to Numerical Data**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "0e22d482",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import LabelEncoder\n",
    "cv = TfidfVectorizer(max_features=10000)\n",
    "x = cv.fit_transform(data['clean']).toarray()\n",
    "\n",
    "\n",
    "y = data['label']\n",
    "label = LabelEncoder()\n",
    "y = label.fit_transform(y)"
   ]
  },
