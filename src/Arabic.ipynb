   "metadata": {},
   "source": [
    "# **Phase 2 : Data preprocessing**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "a29e8e2b",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def processing_text(text):\n",
    "    Stopwords=set(stopwords.words(\"arabic\"))\n",
    "    text = re.sub(r'[^\\u0621-\\u064A\\s]', ' ', text)\n",
    "    tokens=word_tokenize(text)\n",
    "    punctuations = set(string.punctuation)\n",
    "    stemmer = ISRIStemmer()\n",
    "    new_text=[ stemmer.stem(i) for i in tokens if (i not in Stopwords) and (i not in punctuations)]\n",
    "    retunred_text=' '.join(new_text)\n",
    "    return retunred_text"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "821d17bb",
   "metadata": {},
   "outputs": [],
   "source": [
    "data['clean']=data['text'].apply(processing_text)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "f948253e",
   "metadata": {},
   "outputs": [],
   "source": [
    "data.to_csv(\"../data/arabic_cleaned.csv\")"
   ]
