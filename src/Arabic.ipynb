   "source": [
    "import pandas as pd\n",
    "import nltk\n",
    "from nltk import word_tokenize, ISRIStemmer \n",
    "from nltk.corpus import stopwords\n",
    "import string\n",
    "import re\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer"
